{
  "name": "program",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "serve": "vite dev",
    "build": "vue-tsc --noEmit && vite build",
    "ionic:serve": "vite dev",
    "ionic:build": "vue-tsc --noEmit && vite build",
    "e2e": "cypress run",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "serve:pwa": "vite build --mode pwa && vite preview --host --mode pwa",
    "serve:dist": "vite preview",
    "deploy": "vue-tsc --noEmit && vite build && firebase deploy --only hosting",
    "updates": "pnpm i -g @ionic/cli @angular/cli firebase-tools && pnpm self-update"
  },
  "dependencies": {
    "@ionic/core": "^8.8.6",
    "@ionic/vue": "^8.8.6",
    "@ionic/vue-router": "^8.8.6",
    "core-js": "^3.49.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^29.1.1",
    "jshint": "^2.13.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vue-tsc": "^3.2.8"
  },
